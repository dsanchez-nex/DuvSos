// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────

enum HabitState {
  Active
  Paused
  Archived
}

enum GoalType {
  Daily
  Weekly
  Monthly
  Ratio
}

// ─── Core Models ─────────────────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  image     String?
  tagline   String?  @default("Productivity Enthusiast")
  theme     String   @default("system")
  visualTheme String @default("classic")
  checklistAlertDays Int @default(3)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  habits              Habit[]
  todos               Todo[]
  todoCategories      TodoCategory[]
  checklists          Checklist[]
  checklistCategories ChecklistCategory[]
  reminders           Reminder[]
  categories          Category[]
  objectives          Objective[]
  userProgression     UserProgression?
  energyLogs          EnergyLog[]
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  color     String   @default("#3b82f6")
  icon      String   @default("folder")
  createdAt DateTime @default(now())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  habits    Habit[]

  @@index([userId])
}

model Habit {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  color       String    @default("#3b82f6")

  // Lifecycle & Planning
  state       HabitState @default(Active)
  isPermanent Boolean    @default(true)
  startDate   DateTime?
  endDate     DateTime?

  // Goal Configuration
  goalType    GoalType   @default(Daily)
  goalValue   Int        @default(1)

  // Relations
  userId      Int?
  user        User?      @relation(fields: [userId], references: [id])
  categoryId  Int?
  category    Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  objectiveId Int?
  objective   Objective? @relation(fields: [objectiveId], references: [id], onDelete: SetNull)

  completions HabitCompletion[]
  blockers    HabitBlocker[] @relation("BlockedHabit")
  blocking    HabitBlocker[] @relation("BlockerHabit")

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([state])
  @@index([endDate])
  @@index([categoryId])
  @@index([objectiveId])
}

model HabitCompletion {
  id          Int      @id @default(autoincrement())
  habitId     Int
  date        DateTime // normalized to midnight (UTC)
  completedAt DateTime @default(now())
  habit       Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([habitId])
  @@index([habitId, date])
}

model HabitBlocker {
  id             Int   @id @default(autoincrement())
  habitId        Int
  blockerHabitId Int
  habit          Habit @relation("BlockedHabit", fields: [habitId], references: [id], onDelete: Cascade)
  blockerHabit   Habit @relation("BlockerHabit", fields: [blockerHabitId], references: [id], onDelete: Cascade)

  @@unique([habitId, blockerHabitId])
  @@index([habitId])
  @@index([blockerHabitId])
}

model UserProgression {
  id           Int    @id @default(autoincrement())
  userId       Int    @unique
  totalXP      Int    @default(0)
  currentLevel Int    @default(1)
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EnergyLog {
  id     Int      @id @default(autoincrement())
  userId Int
  date   DateTime // normalized to midnight
  level  Int      // 1–5
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([userId, date])
}

model Objective {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  color       String   @default("#3b82f6")
  createdAt   DateTime @default(now())
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id])
  habits      Habit[]

  @@index([userId])
}

// ─── Existing Models (unchanged) ─────────────────────────────────────────

model ChecklistCategory {
  id         Int         @id @default(autoincrement())
  name       String
  color      String      @default("#3b82f6")
  icon       String      @default("folder")
  createdAt  DateTime    @default(now())
  userId     Int?
  user       User?       @relation(fields: [userId], references: [id])
  checklists Checklist[]

  @@index([userId])
}

model Checklist {
  id          Int                @id @default(autoincrement())
  title       String
  description String?
  color       String             @default("#3b82f6")
  startDate   DateTime?
  endDate     DateTime?
  isTemplate  Boolean            @default(false)
  version     Int                @default(1)
  lifecycleState String          @default("Active")
  templateId  Int?
  recurrencePattern String?
  completedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  userId      Int?
  user        User?              @relation(fields: [userId], references: [id])
  categoryId  Int?
  category    ChecklistCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  items       ChecklistItem[]

  @@index([userId])
  @@index([categoryId])
  @@index([lifecycleState])
}

model ChecklistItem {
  id              Int       @id @default(autoincrement())
  title           String
  completed       Boolean   @default(false)
  position        Int       @default(0)
  notes           String?
  priority        String    @default("normal") // low, normal, high
  parentId        Int?
  blockedByItemId Int?
  effortEstimate  Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  checklistId     Int
  checklist       Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
  @@index([checklistId, position])
  @@index([parentId])
  @@index([blockedByItemId])
}

model Todo {
  id           Int       @id @default(autoincrement())
  title        String
  description  String?
  completed    Boolean   @default(false)
  priority     String    @default("normal") // low, normal, high
  dueDate      DateTime?
  dueTime      String?
  effortMinutes Int      @default(0)
  position     Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  userId       Int?
  user         User?     @relation(fields: [userId], references: [id])
  parentId     Int?
  parent       Todo?     @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  subTasks     Todo[]    @relation("SubTasks")
  categoryId   Int?
  category     TodoCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, completed, position])
  @@index([parentId])
  @@index([categoryId])
}

model TodoCategory {
  id          Int       @id @default(autoincrement())
  name        String
  color       String    @default("#3b82f6")
  icon        String    @default("folder")
  description String?
  parentId    Int?
  parent      TodoCategory? @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    TodoCategory[] @relation("CategoryTree")
  createdAt   DateTime  @default(now())
  userId      Int?
  user        User?     @relation(fields: [userId], references: [id])
  todos       Todo[]

  @@index([userId])
  @@index([parentId])
}

model Reminder {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  dueDate     DateTime
  completed   Boolean  @default(false)
  priority    String   @default("normal") // low, normal, high
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, completed, dueDate])
}
