// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  image     String?
  tagline   String?  @default("Productivity Enthusiast")
  theme     String   @default("system")
  checklistAlertDays Int @default(3)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  habits              Habit[]
  todos               Todo[]
  todoCategories      TodoCategory[]
  checklists          Checklist[]
  checklistCategories ChecklistCategory[]
  reminders           Reminder[]
}

model Habit {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  color       String       @default("#3b82f6")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userId      Int?
  user        User?        @relation(fields: [userId], references: [id])
  completions Completion[]

  @@index([userId])
}

model Completion {
  id      Int      @id @default(autoincrement())
  habitId Int
  date    DateTime @default(now())
  habit   Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([habitId])
}

model ChecklistCategory {
  id         Int         @id @default(autoincrement())
  name       String
  color      String      @default("#3b82f6")
  icon       String      @default("folder")
  createdAt  DateTime    @default(now())
  userId     Int?
  user       User?       @relation(fields: [userId], references: [id])
  checklists Checklist[]

  @@index([userId])
}

model Checklist {
  id          Int                @id @default(autoincrement())
  title       String
  description String?
  color       String             @default("#3b82f6")
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  userId      Int?
  user        User?              @relation(fields: [userId], references: [id])
  categoryId  Int?
  category    ChecklistCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  items       ChecklistItem[]

  @@index([userId])
  @@index([categoryId])
}

model ChecklistItem {
  id          Int       @id @default(autoincrement())
  title       String
  completed   Boolean   @default(false)
  position    Int       @default(0)
  notes       String?
  priority    String    @default("normal") // low, normal, high
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  checklistId Int
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
  @@index([checklistId, position])
}

model Todo {
  id           Int       @id @default(autoincrement())
  title        String
  description  String?
  completed    Boolean   @default(false)
  priority     String    @default("normal") // low, normal, high
  dueDate      DateTime?
  dueTime      String?
  effortMinutes Int      @default(0)
  position     Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  userId       Int?
  user         User?     @relation(fields: [userId], references: [id])
  parentId     Int?
  parent       Todo?     @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  subTasks     Todo[]    @relation("SubTasks")
  categoryId   Int?
  category     TodoCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, completed, position])
  @@index([parentId])
  @@index([categoryId])
}

model TodoCategory {
  id          Int       @id @default(autoincrement())
  name        String
  color       String    @default("#3b82f6")
  icon        String    @default("folder")
  description String?
  parentId    Int?
  parent      TodoCategory? @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    TodoCategory[] @relation("CategoryTree")
  createdAt   DateTime  @default(now())
  userId      Int?
  user        User?     @relation(fields: [userId], references: [id])
  todos       Todo[]

  @@index([userId])
  @@index([parentId])
}

model Reminder {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  dueDate     DateTime
  completed   Boolean  @default(false)
  priority    String   @default("normal") // low, normal, high
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, completed, dueDate])
}
